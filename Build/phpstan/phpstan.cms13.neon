parameters:
  level: 8
  reportUnmatchedIgnoredErrors: false
  paths:
    - ../../Classes
    - ../../Configuration
  excludePaths:
    - ../../Classes/Updates
    - ../../Classes/Service/Frontend/LegacyFrontendService.php
    - ../../Classes/Service/Hmac/LegacyHmacGeneratorService.php
    - ../../Classes/Service/StandaloneView/LegacyStandaloneViewService.php
  ignoreErrors:
    - '#defaultCacheTimoutInSeconds#'
  typo3:
    requestGetAttributeMapping:
        frontend.page.information: TYPO3\CMS\Frontend\Page\PageInformation
        handlerRequest: string
        nonce: TYPO3\CMS\Core\Security\ContentSecurityPolicy\ConsumableNonce
        moduleData: TYPO3\CMS\Backend\Module\ModuleData
